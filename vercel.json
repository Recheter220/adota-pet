{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "outputDirectory": "public",
    "framework": null,
    "functions": {
        "/index.php": {
            "runtime": "vercel-php@0.7.4"
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.php"
        }
    ],
    "buildCommand": "echo skip..."
}
